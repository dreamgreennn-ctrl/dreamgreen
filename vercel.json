{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/product/:slug", "destination": "/product.html" },
    { "source": "/collection/:slug", "destination": "/collection.html" },
    { "source": "/blog/:slug", "destination": "/blog.html" }
  ],
  "headers": [
    {
      "source": "/(.*).(fbx|obj|gltf|glb|bin)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(jpg|jpeg|png|webp|svg|gif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, must-revalidate" }
      ]
    }
  ]
}
